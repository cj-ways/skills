{
  "name": "dead-code-react",
  "skill": "find-unused",
  "description": "React app with dead exports, orphaned files, unused hooks, and dead dependencies. Includes barrel file re-exports and dynamic imports that should NOT be flagged.",
  "expected": [
    {
      "id": "unused-export-formatCurrency",
      "description": "formatCurrency exported from utils/format.js but never imported",
      "file": "src/utils/format.js",
      "type": "unused-export",
      "mustFind": true
    },
    {
      "id": "unused-export-debugLog",
      "description": "debugLog exported from utils/logger.js but never imported",
      "file": "src/utils/logger.js",
      "type": "unused-export",
      "mustFind": true
    },
    {
      "id": "orphaned-file-old-dashboard",
      "description": "OldDashboard.jsx is not imported anywhere",
      "file": "src/components/OldDashboard.jsx",
      "type": "orphaned-file",
      "mustFind": true
    },
    {
      "id": "orphaned-file-unused-hook",
      "description": "useLocalStorage.js is not imported anywhere",
      "file": "src/hooks/useLocalStorage.js",
      "type": "orphaned-file",
      "mustFind": true
    },
    {
      "id": "dead-dep-moment",
      "description": "moment is in dependencies but never imported",
      "file": "package.json",
      "type": "dead-dependency",
      "mustFind": true
    }
  ],
  "falsePositives": [
    {
      "id": "fp-barrel-reexport",
      "description": "formatDate is re-exported through utils/index.js barrel and used in App.jsx",
      "file": "src/utils/format.js",
      "export": "formatDate",
      "mustNotFlag": true
    },
    {
      "id": "fp-dynamic-import",
      "description": "LazyComponent is dynamically imported via React.lazy",
      "file": "src/components/LazyComponent.jsx",
      "mustNotFlag": true
    },
    {
      "id": "fp-used-hook",
      "description": "useDebounce is imported and used in SearchBar.jsx",
      "file": "src/hooks/useDebounce.js",
      "mustNotFlag": true
    }
  ]
}
